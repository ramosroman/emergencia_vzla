# API Key de Google Gemini (obligatoria para extracción VLM)
GEMINI_API_KEY=tu_api_key_aqui

# Modelo de Gemini a usar (2.0-flash-lite es más económico, 2.0-flash es más preciso)
GEMINI_MODEL=gemini-2.0-flash-lite

# Base de datos PostgreSQL
DATABASE_URL=postgresql+asyncpg://app:app_secret_123@localhost:5432/pacientes

# Directorio para almacenar imágenes subidas
UPLOAD_DIR=./uploads

# Orígenes permitidos para CORS (separados por coma, * para todos)
CORS_ORIGINS=*
